            "in": "body",
            "name": "body",
            "x-examples": {
              "example": {
                "paid_date": "2021-01-19",
                "amount": 1000,
                "slip": null
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "no response description was provided for this operation"
          }
        }
      },
      "parameters": [
        {
          "type": "string",
          "name": "invoiceId",
